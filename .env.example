# =============================================================================
# Environment Variables — copy this to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ---------------------------------------------------------------------------
# Neo4j — Deterministic Memory (primary system)
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ---------------------------------------------------------------------------
# Neo4j — Graphiti by Zep (comparison system, separate instance)
# ---------------------------------------------------------------------------
NEO4J_GRAPHITI_URI=bolt://localhost:7689
NEO4J_GRAPHITI_USER=neo4j
NEO4J_GRAPHITI_PASSWORD=

# ---------------------------------------------------------------------------
# Qdrant — Mem0 + Basic RAG vector store (comparison systems)
# ---------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333

# ---------------------------------------------------------------------------
# OpenAI — Required ONLY for Mem0 and Graphiti comparison benchmarks
# Not needed to run the deterministic system
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
